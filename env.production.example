# =============================================================================
# .env.production.example — Production Environment Variables Template
# =============================================================================
#
# HOW TO USE:
#   1. Copy this file:    cp env.production.example .env.production
#   2. Fill in every value (no empty strings allowed in production)
#   3. NEVER commit .env.production to Git
#
# WHERE THESE ARE USED:
#   - Local manual deploy: deploy-ibmcloud.sh reads .env.production
#   - GitHub Actions:      Add each value as a GitHub Secret
#   - IBM Code Engine:     Set each as an environment variable in the console
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
ENV=production
DEBUG=false

# JWT secret — generate a strong random key:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX

# URL of the deployed frontend (after deploying)
# Format: https://<your-app-name>.<region>.codeengine.appdomain.cloud
FRONTEND_URL=https://interview-trainer.us-south.codeengine.appdomain.cloud

# ── Database (PostgreSQL on IBM Cloud Databases) ───────────────────────────────
# Format: postgresql://user:password@host:port/dbname?sslmode=require
# Get this from: IBM Cloud → Databases for PostgreSQL → Connection Details
DATABASE_URL=postgresql://admin:REPLACE_PASSWORD@REPLACE_HOST:5432/interviewdb?sslmode=require

# ── IBM watsonx.ai ────────────────────────────────────────────────────────────
# Get these from: https://cloud.ibm.com/iam/apikeys and watsonx.ai project
WATSONX_API_KEY=REPLACE_WITH_YOUR_IBM_API_KEY
WATSONX_PROJECT_ID=REPLACE_WITH_YOUR_PROJECT_UUID
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# IBM Granite model IDs (these are the correct production IDs)
GRANITE_MODEL_ID=ibm/granite-13b-chat-v2
GRANITE_EMBED_MODEL_ID=ibm/slate-125m-english-rtrvr

# ── IBM Cloud Object Storage ──────────────────────────────────────────────────
# Get from: IBM Cloud → Cloud Object Storage → Service Credentials
COS_API_KEY=REPLACE_WITH_COS_API_KEY
COS_INSTANCE_CRN=REPLACE_WITH_COS_CRN
COS_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud
COS_BUCKET_NAME=interview-trainer-resumes

# ── ChromaDB (persisted inside container) ────────────────────────────────────
# In production, ChromaDB runs inside the container.
# The knowledge base is rebuilt from datasets/ on every cold start.
# For a persistent external vector DB, migrate to IBM watsonx.data later.
CHROMA_PERSIST_DIR=/app/chroma_db
CHROMA_COLLECTION_NAME=interview_knowledge_base

# ── File upload limits ────────────────────────────────────────────────────────
UPLOAD_DIR=/tmp/uploads
MAX_FILE_SIZE_MB=10
