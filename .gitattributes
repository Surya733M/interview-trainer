# Normalise line endings
* text=auto

# Force Unix line endings for all code files
*.py   text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.css  text eol=lf
*.html text eol=lf

# Binary files - do not modify
*.png  binary
*.jpg  binary
*.pdf  binary
*.db   binary