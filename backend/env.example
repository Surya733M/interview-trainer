# ══════════════════════════════════════════════════════
#  Interview Trainer Agent — Environment Variables
#  ⚠️  NEVER commit this file to Git
#  Copy this file, fill in your real values
# ══════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────
APP_NAME="Interview Trainer Agent"
APP_VERSION="1.0.0"
DEBUG=true
# Secret key for signing JWT tokens — change this to a random 64-char string in prod
SECRET_KEY="dev-secret-key-change-this-in-production-make-it-long-and-random"
ALGORITHM="HS256"
# Token expiry in minutes (60 = 1 hour)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ──────────────────────────────────────────
# SQLite for development (file-based, zero setup)
DATABASE_URL="sqlite:///./interview_trainer.db"
# PostgreSQL for production (uncomment and fill in prod):
# DATABASE_URL="postgresql://user:password@localhost:5432/interview_trainer"

# ── IBM watsonx.ai ────────────────────────────────────
# Get from: IBM Cloud → Manage → API Keys
WATSONX_API_KEY="your-ibm-cloud-api-key-here"
# Get from: watsonx.ai → Your Project → Manage → General → Project ID
WATSONX_PROJECT_ID="your-watsonx-project-id-here"
# Region endpoint (us-south is default for Lite tier)
WATSONX_URL="https://us-south.ml.cloud.ibm.com"

# ── IBM Granite Model IDs ─────────────────────────────
# Text generation model
GRANITE_MODEL_ID="ibm/granite-13b-chat-v2"
# Embedding model (for RAG vector search)
GRANITE_EMBED_MODEL_ID="ibm/slate-125m-english-rtrvr"

# ── IBM Cloud Object Storage ─────────────────────────
# Get from: IBM Cloud → Cloud Object Storage → Service Credentials
COS_API_KEY="your-cos-api-key-here"
COS_INSTANCE_CRN="your-cos-instance-crn-here"
COS_ENDPOINT="https://s3.us-south.cloud-object-storage.appdomain.cloud"
COS_BUCKET_NAME="interview-trainer-resumes"

# ── ChromaDB ──────────────────────────────────────────
# Local persistent storage path for vector database
CHROMA_PERSIST_DIR="./chroma_db"
CHROMA_COLLECTION_NAME="interview_knowledge_base"

# ── File Upload Settings ──────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS="pdf"

# ── CORS ──────────────────────────────────────────────
# Frontend URL (Vite dev server default port)
FRONTEND_URL="http://localhost:5173"
