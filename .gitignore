# =============================================
#  Interview Trainer Agent — .gitignore
# =============================================

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.pytest_cache/
.coverage
htmlcov/

# ── Virtual Environment (NEVER commit) ────────
venv/
.venv/
env/
ENV/

# ── Secrets (NEVER commit) ────────────────────
.env
*.env.local
*.env.production

# ── Databases ─────────────────────────────────
*.db
*.sqlite3

# ── User Uploads (contains PII) ───────────────
backend/uploads/*
!backend/uploads/.gitkeep

# ── Generated Reports ─────────────────────────
backend/reports/*
!backend/reports/.gitkeep

# ── Vector Store (large binary files) ─────────
backend/chroma_db/*
!backend/chroma_db/.gitkeep

# ── Log Files ─────────────────────────────────
*.log
logs/
backend/logs/

# ── AI Model Weights (too large for GitHub) ───
*.bin
*.pt
*.pth
*.onnx
models/

# ── IDE ───────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Node / Frontend ───────────────────────────
node_modules/
frontend/dist/
frontend/build/
frontend/.env
frontend/.env.local

# ── Coverage ──────────────────────────────────
coverage/
.nyc_output/